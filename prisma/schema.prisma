// نظام إدارة مكتب المحاماة — مخطط قاعدة البيانات
// Prisma schema — Law Office Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
//  المستخدمون والصلاحيات  —  Users & Roles
// ===========================================================================

enum Role {
  ADMIN // مدير المكتب — كل الصلاحيات
  LAWYER // محامي
  PARALEGAL // مساعد قانوني
  SECRETARY // سكرتير
  ACCOUNTANT // محاسب
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(SECRETARY)
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // من أنشأ هذا الحساب (الأدمن)
  createdById  String?
  createdBy    User?   @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[]  @relation("UserCreatedBy")

  sessions                Session[]
  createdClients          Client[]             @relation("ClientCreatedBy")
  createdCases            Case[]               @relation("CaseCreatedBy")
  assignedCases           Case[]               @relation("CaseAssignedLawyer")
  uploadedDocs            Document[]
  createdTasks            Task[]               @relation("TaskCreatedBy")
  assignedTasks           Task[]               @relation("TaskAssignedTo")
  taskComments            TaskComment[]
  caseNotes               CaseNote[]
  createdEvents           Event[]
  auditLogs               AuditLog[]
  createdContracts        Contract[]
  createdServiceRequests  ServiceRequest[]     @relation("ServiceRequestCreatedBy")
  assignedServiceRequests ServiceRequest[]     @relation("ServiceRequestAssignedTo")
  serviceRequestNotes     ServiceRequestNote[]
  createdContacts         LegalContact[]       @relation("LegalContactCreatedBy")
  createdPowers           PowerOfAttorney[]    @relation("PowerCreatedBy")
  createdLitigationSteps  LitigationStep[]     @relation("LitigationStepCreatedBy")
  assignedLitigationSteps LitigationStep[]     @relation("LitigationStepAssignedTo")
  createdDocumentRequests DocumentRequest[]    @relation("DocumentRequestCreatedBy")
  createdInvoices         Invoice[]            @relation("InvoiceCreatedBy")
  createdPayments         Payment[]            @relation("PaymentCreatedBy")
  createdExpenses         JudicialExpense[]    @relation("ExpenseCreatedBy")
  createdTemplates        LegalTemplate[]      @relation("TemplateCreatedBy")
  createdTemplateOutputs  TemplateOutput[]     @relation("TemplateOutputCreatedBy")
  createdMessageTemplates MessageTemplate[]    @relation("MessageTemplateCreatedBy")
  createdReminders        Reminder[]           @relation("ReminderCreatedBy")
  assignedReminders       Reminder[]           @relation("ReminderAssignedTo")
  approvalRequests        ApprovalRequest[]    @relation("ApprovalRequestedBy")
  approvalDecisions       ApprovalRequest[]    @relation("ApprovalDecidedBy")

  notifications         Notification[]      @relation("UserNotifications")
  messagesSent          Message[]           @relation("MessagesSent")
  messagesReceived      Message[]           @relation("MessagesReceived")
  caseMessages          CaseMessage[]       @relation("CaseMessageStaffAuthor")
  createdConsultations  LegalConsultation[] @relation("ConsultationCreatedBy")
  assignedConsultations LegalConsultation[] @relation("ConsultationAssignedTo")
  createdLibraryEntries LegalLibraryEntry[] @relation("LibraryEntryCreatedBy")
  createdHearingMinutes HearingMinute[]     @relation("HearingMinuteCreatedBy")

  @@index([role])
  @@index([isActive])
}

// ===========================================================================
//  الإشعارات  —  Notifications
// ===========================================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String // المستلِم
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String // مثال: task.assigned, task.comment, case.note, message, event.soon
  title     String
  body      String?
  link      String? // المسار الذي يفتحه الإشعار عند الضغط
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

// ===========================================================================
//  الرسائل الداخلية بين الموظفين  —  Internal Messages
// ===========================================================================

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User     @relation("MessagesReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  body        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, read])
  @@index([senderId])
  @@index([createdAt])
}

// جلسات الدخول — تُخزَّن في قاعدة البيانات حتى يمكن إلغاؤها فوراً
model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique // نخزّن هاش التوكن فقط، وليس التوكن نفسه
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  ip        String?
  userAgent String?

  @@index([userId])
  @@index([expiresAt])
}

// ===========================================================================
//  الموكّلون  —  Clients
// ===========================================================================

enum ClientType {
  INDIVIDUAL // فرد
  COMPANY // منشأة / قطاع تجاري
}

model Client {
  id            String     @id @default(cuid())
  type          ClientType @default(INDIVIDUAL)
  name          String // اسم الشخص أو الممثّل
  // بيانات الفرد
  nationalId    String? // رقم الهوية الوطنية
  nationality   String? // الجنسية
  // بيانات المنشأة التجارية
  companyName   String? // اسم الشركة
  unifiedNumber String? // الرقم الوطني الموحّد
  taxNumber     String? // الرقم الضريبي
  // بيانات التواصل
  phone         String?
  email         String?
  address       String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // بوابة العميل — دخول منفصل عن الموظفين
  portalEnabled      Boolean @default(false)
  portalEmail        String? @unique
  portalPasswordHash String?

  createdById String?
  createdBy   User?   @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  cases            Case[]
  contracts        Contract[]
  serviceRequests  ServiceRequest[]
  legalContacts    LegalContact[]
  powersOfAttorney PowerOfAttorney[]
  invoices         Invoice[]
  payments         Payment[]
  expenses         JudicialExpense[]
  templateOutputs  TemplateOutput[]
  reminders        Reminder[]
  portalSessions   ClientSession[]
  consultations    LegalConsultation[]
  caseMessages     CaseMessage[]       @relation("CaseMessageClientAuthor")

  @@index([name])
}

// جلسات دخول العميل للبوابة (منفصلة تماماً عن جلسات الموظفين)
model ClientSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  ip        String?
  userAgent String?

  @@index([clientId])
  @@index([expiresAt])
}

// ===========================================================================
//  القضايا  —  Cases
// ===========================================================================

enum CaseStatus {
  OPEN // مفتوحة
  IN_PROGRESS // جارية
  POSTPONED // مؤجلة
  WON // كُسبت
  LOST // خُسرت
  CLOSED // مغلقة
  ARCHIVED // مؤرشفة
}

enum CaseType {
  CIVIL // مدني
  CRIMINAL // جنائي
  COMMERCIAL // تجاري
  FAMILY // أحوال شخصية
  LABOR // عمالي
  ADMINISTRATIVE // إداري
  OTHER // أخرى
}

model Case {
  id          String     @id @default(cuid())
  caseNumber  String     @unique // رقم القضية
  title       String
  court       String? // المحكمة
  caseType    CaseType   @default(OTHER)
  status      CaseStatus @default(OPEN)
  description String?
  openedAt    DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?   @relation("CaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  assignedLawyerId String?
  assignedLawyer   User?   @relation("CaseAssignedLawyer", fields: [assignedLawyerId], references: [id], onDelete: SetNull)

  documents        Document[]
  documentRequests DocumentRequest[]
  tasks            Task[]
  notes            CaseNote[]
  events           Event[]
  contracts        Contract[]
  serviceRequests  ServiceRequest[]
  legalContacts    LegalContact[]
  powersOfAttorney PowerOfAttorney[]
  litigationSteps  LitigationStep[]
  invoices         Invoice[]
  expenses         JudicialExpense[]
  templateOutputs  TemplateOutput[]
  reminders        Reminder[]
  consultations    LegalConsultation[]
  caseMessages     CaseMessage[]
  hearingMinutes   HearingMinute[]

  @@index([status])
  @@index([caseType])
  @@index([clientId])
  @@index([assignedLawyerId])
}

// ملاحظات داخلية على القضية (تواصل بين الموظفين)
model CaseNote {
  id        String   @id @default(cuid())
  body      String
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([caseId])
}

// ===========================================================================
//  المستندات  —  Documents
// ===========================================================================

enum DocumentRequestStatus {
  REQUESTED
  RECEIVED
  WAIVED
}

enum DocumentOcrStatus {
  NOT_INDEXED
  INDEXED
  NEEDS_OCR
  FAILED
}

model Document {
  id            String             @id @default(cuid())
  title         String
  fileName      String
  storageKey    String // مسار/مفتاح الملف في التخزين
  mimeType      String?
  sizeBytes     Int?
  category      String?
  tags          String?
  visibility    DocumentVisibility @default(PORTAL)
  expiresAt     DateTime?
  notes         String?
  extractedText String?
  ocrStatus     DocumentOcrStatus  @default(NOT_INDEXED)
  indexedAt     DateTime?
  caseId        String
  case          Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedById  String?
  uploadedBy    User?              @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())

  @@index([caseId])
  @@index([category])
  @@index([visibility])
  @@index([expiresAt])
  @@index([ocrStatus])
}

model DocumentRequest {
  id          String                @id @default(cuid())
  title       String
  category    String?
  description String?
  dueDate     DateTime?
  status      DocumentRequestStatus @default(REQUESTED)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("DocumentRequestCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([status])
  @@index([dueDate])
}

// ===========================================================================
//  المهام  —  Tasks
// ===========================================================================

enum TaskStatus {
  TODO // للعمل
  IN_PROGRESS // جارية
  DONE // منتهية
  CANCELLED // ملغاة
}

enum TaskPriority {
  LOW // منخفضة
  MEDIUM // متوسطة
  HIGH // عالية
  URGENT // عاجلة
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  comments TaskComment[]

  @@index([status])
  @@index([assignedToId])
  @@index([caseId])
}

// تعليقات على المهمة (تواصل بين الموظفين)
model TaskComment {
  id        String   @id @default(cuid())
  body      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([taskId])
}

// ===========================================================================
//  التقويم والمواعيد  —  Calendar & Events
// ===========================================================================

enum EventType {
  HEARING // جلسة محكمة
  MEETING // اجتماع
  DEADLINE // موعد نهائي
  APPOINTMENT // موعد
  OTHER // أخرى
}

model Event {
  id        String    @id @default(cuid())
  title     String
  type      EventType @default(HEARING)
  startAt   DateTime
  endAt     DateTime?
  location  String?
  notes     String?
  createdAt DateTime  @default(now())

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([startAt])
  @@index([caseId])
}

// ===========================================================================
//  بيانات الشركة/المكتب  —  Firm Settings (سجل واحد)
// ===========================================================================

model FirmSettings {
  id            String   @id @default("firm")
  name          String   @default("مكتب المحاماة") // اسم الشركة كاملاً
  legalForm     String? // الشكل القانوني (مهنية شخص واحد ذات مسؤولية محدودة)
  licenseNumber String? // رقم شهادة تسجيل الشركة المهنية
  address       String? // العنوان الرئيسي (المدينة)
  branches      String? // الفروع
  phones        String? // الجوالات
  email         String? // البريد الإلكتروني
  taxNumber     String? // الرقم الضريبي للشركة
  managerName   String? // اسم المدير العام / الممثّل بالتوقيع
  city          String? // مدينة الاختصاص القضائي
  updatedAt     DateTime @updatedAt
}

// ===========================================================================
//  اتفاقيات الأتعاب  —  Fee Agreements / Contracts
// ===========================================================================

enum ContractStatus {
  DRAFT // مسودّة
  SENT // مرسلة للعميل بانتظار التوقيع
  CLIENT_SIGNED // وقّع العميل وبانتظار اعتماد المكتب
  ACTIVE // سارية
  COMPLETED // منتهية
  CANCELLED // ملغاة
}

model Contract {
  id     String @id @default(cuid())
  number String // رقم الاتفاقية (مثال: 47/73/ج)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  city          String? // مدينة الإبرام
  dateHijri     String? // التاريخ الهجري (نص)
  dateGregorian DateTime? // التاريخ الميلادي
  scope         String // مهام الطرف الأول (المتفق عليها)

  // المبالغ محفوظة بالهللة (1 ريال = 100 هللة) لتفادي أخطاء الكسور
  amountBeforeTax Int // المبلغ قبل الضريبة
  taxRate         Int  @default(15) // نسبة ضريبة القيمة المضافة %
  installments    Json // مصفوفة الدفعات: [{ amount, note, paid }]

  notes     String?
  status    ContractStatus @default(DRAFT)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  invoices Invoice[]

  @@index([clientId])
  @@index([status])
}

// ===========================================================================
//  طلبات الخدمات القانونية  —  Legal Service Requests
// ===========================================================================

enum ServiceArea {
  CONTACTS // جهات الاتصال والعلاقات القانونية
  LITIGATION // التقاضي والقضايا
  POWER_OF_ATTORNEY // التوكيلات والتفويضات
  CONSULTATION // الاستشارات القانونية
  ADMIN_REQUEST // المهام والطلبات الإدارية
  COMPLAINT // البلاغات والشكاوى
  LEGAL_TEMPLATE // النماذج والصياغات القانونية
  FILE_MANAGEMENT // إدارة الملفات والمستندات
  ALERTS // التنبيهات والمواعيد
  REPORTING // التقارير ولوحات المتابعة
  ACCOUNTING // الحسابات والفواتير
  JUDICIAL_EXPENSE // المصروفات القضائية
  CLIENT_PORTAL // خدمات بوابة العميل
  CONTRACTS // العقود واتفاقيات الأتعاب
  OTHER // أخرى
}

enum DocumentVisibility {
  INTERNAL
  PORTAL
}

enum ServiceRequestStatus {
  NEW // جديد
  IN_REVIEW // قيد المراجعة
  IN_PROGRESS // جار التنفيذ
  WAITING_CLIENT // بانتظار العميل
  COMPLETED // مكتمل
  CANCELLED // ملغى
}

enum ServiceRequestPriority {
  LOW // منخفضة
  MEDIUM // متوسطة
  HIGH // عالية
  URGENT // عاجلة
}

model ServiceRequest {
  id          String                 @id @default(cuid())
  title       String
  serviceArea ServiceArea
  status      ServiceRequestStatus   @default(NEW)
  priority    ServiceRequestPriority @default(MEDIUM)
  description String?
  dueDate     DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("ServiceRequestCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("ServiceRequestAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  notes ServiceRequestNote[]

  @@index([serviceArea])
  @@index([status])
  @@index([priority])
  @@index([clientId])
  @@index([caseId])
  @@index([assignedToId])
}

model ServiceRequestNote {
  id        String         @id @default(cuid())
  body      String
  requestId String
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  @@index([requestId])
}

// ===========================================================================
//  دليل الجهات والتوكيلات والتقاضي  —  Contacts, Powers & Litigation
// ===========================================================================

enum ConsultationStatus {
  NEW
  IN_REVIEW
  OPINION_READY
  CONVERTED
  CLOSED
  CANCELLED
}

enum ConsultationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ConsultationSource {
  PUBLIC_SITE
  CLIENT_PORTAL
  PHONE
  OFFICE
  EMAIL
  OTHER
}

model LegalConsultation {
  id             String               @id @default(cuid())
  title          String
  question       String
  legalOpinion   String?
  recommendation String?
  status         ConsultationStatus   @default(NEW)
  priority       ConsultationPriority @default(MEDIUM)
  source         ConsultationSource   @default(OFFICE)
  requesterName  String?
  requesterPhone String?
  requesterEmail String?
  reviewedAt     DateTime?
  convertedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("ConsultationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("ConsultationAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([clientId])
  @@index([caseId])
  @@index([assignedToId])
  @@index([createdAt])
}

enum LegalContactType {
  COURT
  GOVERNMENT
  OPPONENT
  EXPERT
  LAWYER
  SERVICE_PROVIDER
  CLIENT_REPRESENTATIVE
  OTHER
}

model LegalContact {
  id           String           @id @default(cuid())
  type         LegalContactType @default(OTHER)
  name         String
  organization String?
  roleTitle    String?
  phone        String?
  email        String?
  address      String?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("LegalContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([name])
  @@index([clientId])
  @@index([caseId])
}

enum PowerStatus {
  ACTIVE
  EXPIRING
  EXPIRED
  REVOKED
  ARCHIVED
}

model PowerOfAttorney {
  id             String      @id @default(cuid())
  number         String
  title          String
  status         PowerStatus @default(ACTIVE)
  issuedAt       DateTime?
  expiresAt      DateTime?
  issuer         String?
  representative String?
  scope          String?
  notes          String?
  documentUrl    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("PowerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([number])
  @@index([status])
  @@index([expiresAt])
  @@index([clientId])
  @@index([caseId])
}

enum LitigationStage {
  FILING
  FIRST_INSTANCE
  APPEAL
  CASSATION
  EXECUTION
  SETTLEMENT
  CLOSURE
  OTHER
}

enum LitigationStepStatus {
  PLANNED
  IN_PROGRESS
  DONE
  WAITING
  CANCELLED
}

model LitigationStep {
  id          String               @id @default(cuid())
  title       String
  stage       LitigationStage      @default(OTHER)
  status      LitigationStepStatus @default(PLANNED)
  priority    TaskPriority         @default(MEDIUM)
  court       String?
  circuit     String?
  sessionDate DateTime?
  dueDate     DateTime?
  outcome     String?
  nextAction  String?
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("LitigationStepCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("LitigationStepAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  hearingMinutes HearingMinute[]

  @@index([caseId])
  @@index([stage])
  @@index([status])
  @@index([sessionDate])
  @@index([dueDate])
  @@index([assignedToId])
}

// ===========================================================================
//  المالية والمصروفات  —  Finance & Judicial Expenses
// ===========================================================================

model HearingMinute {
  id               String    @id @default(cuid())
  sessionDate      DateTime
  court            String?
  circuit          String?
  decision         String
  requirements     String?
  nextSessionAt    DateTime?
  notes            String?
  generatedTaskId  String?
  generatedEventId String?
  createdAt        DateTime  @default(now())

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  litigationStepId String?
  litigationStep   LitigationStep? @relation(fields: [litigationStepId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("HearingMinuteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([sessionDate])
  @@index([nextSessionAt])
  @@index([createdById])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id              String        @id @default(cuid())
  number          String        @unique
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  amountBeforeTax Int
  taxRate         Int           @default(15)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  payments Payment[]

  @@index([status])
  @@index([clientId])
  @@index([caseId])
  @@index([contractId])
  @@index([dueDate])
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  CHECK
  ONLINE
  OTHER
}

model Payment {
  id        String        @id @default(cuid())
  amount    Int
  paidAt    DateTime      @default(now())
  method    PaymentMethod @default(BANK_TRANSFER)
  reference String?
  notes     String?
  createdAt DateTime      @default(now())

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?   @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([clientId])
  @@index([paidAt])
}

enum ExpenseStatus {
  PENDING
  APPROVED
  PAID
  REIMBURSED
  REJECTED
}

enum ExpenseCategory {
  COURT_FEE
  EXPERT_FEE
  ENFORCEMENT
  PUBLICATION
  TRANSPORTATION
  TRANSLATION
  GOVERNMENT_FEE
  OTHER
}

model JudicialExpense {
  id         String          @id @default(cuid())
  title      String
  category   ExpenseCategory @default(OTHER)
  status     ExpenseStatus   @default(PENDING)
  amount     Int
  incurredAt DateTime        @default(now())
  dueDate    DateTime?
  paidAt     DateTime?
  vendor     String?
  receiptUrl String?
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([status])
  @@index([clientId])
  @@index([caseId])
  @@index([dueDate])
}

// ===========================================================================
//  النماذج القانونية والتذكيرات  —  Templates & Reminders
// ===========================================================================

enum LegalTemplateCategory {
  CONTRACT
  MEMO
  WARNING
  LETTER
  POWER
  LAWSUIT
  EXECUTION
  OTHER
}

enum LibraryEntryType {
  PRINCIPLE
  JUDGMENT
  NOTE
  PROCEDURE
  FORM
  OTHER
}

model LegalLibraryEntry {
  id           String           @id @default(cuid())
  title        String
  type         LibraryEntryType @default(NOTE)
  summary      String?
  content      String
  tags         String?
  jurisdiction String?
  court        String?
  sourceUrl    String?
  isPublished  Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  createdById String?
  createdBy   User?   @relation("LibraryEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([isPublished])
  @@index([createdAt])
}

model LegalTemplate {
  id        String                @id @default(cuid())
  title     String
  category  LegalTemplateCategory @default(OTHER)
  body      String
  variables String?
  notes     String?
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  createdById String?
  createdBy   User?   @relation("TemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  outputs TemplateOutput[]

  @@index([category])
  @@index([isActive])
}

model TemplateOutput {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())

  templateId String?
  template   LegalTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("TemplateOutputCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([clientId])
  @@index([caseId])
}

enum MessageTemplateChannel {
  EMAIL
  WHATSAPP
  PORTAL
}

model MessageTemplate {
  id        String                 @id @default(cuid())
  title     String
  channel   MessageTemplateChannel @default(EMAIL)
  trigger   String?
  subject   String?
  body      String
  isActive  Boolean                @default(true)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  createdById String?
  createdBy   User?   @relation("MessageTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([channel])
  @@index([isActive])
}

enum EmailDeliveryStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  CANCELLED
}

model EmailDelivery {
  id            String              @id @default(cuid())
  to            String
  subject       String
  heading       String
  linesJson     String
  actionLabel   String?
  actionUrl     String?
  status        EmailDeliveryStatus @default(QUEUED)
  attempts      Int                 @default(0)
  maxAttempts   Int                 @default(3)
  lastError     String?
  nextAttemptAt DateTime            @default(now())
  sentAt        DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([status, nextAttemptAt])
  @@index([createdAt])
}

enum CaseMessageAuthorType {
  STAFF
  CLIENT
}

model CaseMessage {
  id         String                @id @default(cuid())
  body       String
  authorType CaseMessageAuthorType
  createdAt  DateTime              @default(now())

  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  staffAuthorId String?
  staffAuthor   User?   @relation("CaseMessageStaffAuthor", fields: [staffAuthorId], references: [id], onDelete: SetNull)

  clientAuthorId String?
  clientAuthor   Client? @relation("CaseMessageClientAuthor", fields: [clientAuthorId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@index([authorType])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalType {
  CONTRACT_APPROVAL
  DOCUMENT_VISIBILITY
  DELETE_REQUEST
  FINANCE_DISCOUNT
  GENERAL
}

model ApprovalRequest {
  id           String         @id @default(cuid())
  title        String
  type         ApprovalType   @default(GENERAL)
  status       ApprovalStatus @default(PENDING)
  entityType   String?
  entityId     String?
  reason       String?
  decisionNote String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  decidedAt    DateTime?

  requestedById String?
  requestedBy   User?   @relation("ApprovalRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  decidedById String?
  decidedBy   User?   @relation("ApprovalDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@index([entityType, entityId])
  @@index([requestedById])
}

enum ReminderType {
  HEARING
  TASK
  SERVICE_REQUEST
  POWER_EXPIRY
  INVOICE_DUE
  EXPENSE_DUE
  CUSTOM
}

enum ReminderStatus {
  OPEN
  DONE
  SNOOZED
  CANCELLED
}

model Reminder {
  id        String         @id @default(cuid())
  type      ReminderType   @default(CUSTOM)
  status    ReminderStatus @default(OPEN)
  title     String
  dueAt     DateTime
  link      String?
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  userId String?
  user   User?   @relation("ReminderAssignedTo", fields: [userId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("ReminderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([dueAt])
  @@index([userId])
  @@index([clientId])
  @@index([caseId])
}

// ===========================================================================
//  سجل التدقيق  —  Audit Log
// ===========================================================================

model AuditLog {
  id        String   @id @default(cuid())
  action    String // مثال: "user.login", "case.create"
  entity    String? // نوع الكيان
  entityId  String? // معرّف الكيان
  details   String? // تفاصيل إضافية (JSON)
  ip        String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
