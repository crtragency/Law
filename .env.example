# ==========================================================================
#  إعدادات نظام مكتب المحاماة  —  Law Office System Environment Variables
#  انسخ هذا الملف باسم .env.local واملأ القيم الحقيقية. لا ترفع .env أبداً.
# ==========================================================================

# رابط قاعدة بيانات PostgreSQL
# ----------------------------------------------------------------------------
# مع Supabase: من Project Settings → Database → Connection string
#   الأفضل استخدام "Session pooler" (يعمل على Vercel ويدعم كل العمليات):
#   postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/law_office?schema=public"

# (اختياري) اتصال مباشر يُستخدم فقط لإنشاء/تعديل الجداول (prisma db push).
# لو استخدمت "Transaction pooler" (منفذ 6543) في DATABASE_URL، اضبط هنا الاتصال
# المباشر (منفذ 5432). لو استخدمت Session pooler فوق، مش محتاج DIRECT_URL.
# DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# تخزين الملفات (Supabase Storage) — مطلوبان لتفعيل رفع المستندات الفعلي
# من Supabase → Project Settings → API:
#   Project URL  →  SUPABASE_URL
#   service_role (secret)  →  SUPABASE_SERVICE_ROLE_KEY  (سرّي جداً — لا يُشارك)
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="ضع-مفتاح-service_role-هنا"

# إرسال البريد الإلكتروني (Resend) — لإشعارات بوابة العميل
# من resend.com → API Keys. الإرسال يعمل بدون نطاق مُوثّق فقط لبريدك أثناء
# التجربة؛ للإرسال لأي عميل وثّق نطاقك في Resend وحدّث EMAIL_FROM.
RESEND_API_KEY=""
# المُرسِل — يجب أن يكون على نطاق موثّق في Resend (وليس Gmail)
EMAIL_FROM="مكتب المحاماة <no-reply@your-verified-domain.com>"
# (اختياري) عنوان الرد — تصل إليه ردود العملاء (يصلح أن يكون بريدك على Gmail)
EMAIL_REPLY_TO=""

# رابط الموقع الأساسي (يُستخدم في روابط رسائل البريد)
APP_URL="https://your-app.vercel.app"

# بيانات حساب المدير الأول (تُستخدم مرة واحدة عند تشغيل seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ضع-كلمة-مرور-قوية-هنا"
ADMIN_NAME="مدير المكتب"

# بيئة التشغيل (development أو production)
NODE_ENV="development"
